{# Tells the browser to use modern HTML parsing rules #}
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-TTQVPXCS');</script>
  <!-- End Google Tag Manager -->
  {# Character encoding #}
  <meta
  charset="UTF-8"/> {# Viewport settings for responsive design #}
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title }}</title>
  {# Meta and SEO #}
  {% block meta %}{% endblock meta %}
  {# Favicon for the website #}
  <link rel="icon" type="image/png" href="/assets/favicon/favicon-96x96.png" sizes="96x96"/>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon/favicon.svg"/>
  <link rel="shortcut icon" href="/assets/favicon/favicon.ico"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png"/>
  <meta name="apple-mobile-web-app-title" content="Verawood"/>
  <link rel="manifest" href="/assets/favicon/site.webmanifest"/> {# Additional head elements can be added here #}
  {# Fonts #} <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Sofia+Sans:ital,wght@0,1..1000;1,1..1000&display=swap"
    rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
  href="https://fonts.googleapis.com/css2?family=Manrope:wght@500&display=swap" rel="stylesheet"> {# Styles #}
  <link rel="stylesheet" href="/assets/google-ads/global.css">
  <link
  rel="stylesheet" href="/assets/google-ads/styles.css">
  {# JavaScript files can be included here #}
  {% block head_scripts %}{% endblock head_scripts %}
</head>


<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TTQVPXCS"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  {# Header section of the page #}
  <header id="root-header">
    <div class="imgWrapper"><img src="/assets/logo_dark.svg" alt="Verawood Construction logo" class="log"></div>
    <div class="cta">
      <a class="label --t-big-2" href="tel:+6138940745">Talk To A Kitchen Reno Expert</a>
      <a class="bLink-2" href="tel:+6138940745">(613) 894 - 0745</a>
    </div>
  </header>
  {# Main content of the page #}
  <main id="root-content">
    {% if sections["hero"] %}
    {% set hero = sections["hero"] %}
    <section id="hero" class="section -l-hero --invertColor">
      <h1>{{ hero.heading }}</h1>
      <div class="container1">
        <p class="--t-p-2">{{ hero.intro }}</p>
        <div class="container1-sub">
          <img src="/assets/review_stars.svg" alt="Five star rating" class="reviewIcon">
          <div class="review --t-small"><img class="textIcon" src="/assets/icon_google.svg" alt="Google"> <span>{{ hero.ratingText }}</span>
          </div>
        </div>
      </div>
      <div class="container2">
        <div class="imgWrapper"><img src="{{ hero.image.src }}" alt="{{ hero.image.alt }}"></div>
        <div class="spread">
          <h2>{{ hero.subheading }}</h2>
          <ul class="--ul-1">
            {% for bullet in hero.bullets %}
            <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
          <a class="bLink-2" href="{{ hero.cta.href }}">{{ hero.cta.text }}</a>
        </div>
      </div>
    </section>
    {% endif %}

    {% if sections["highlights"] %}
    {% set highlights = sections["highlights"] %}
    <section id="highlights" class="section cardContainer --bg-2 -layout-3Col_Card_fixed1">
      {% for card in highlights.cards %}
      <div class="card -card-2 -spread-spacing1">
        <p class="--t-big">{{ card.eyebrow }}</p>
        <hr>
        <h3 class="-t-1 -f-iconText-inline1">
          <div class="icon">
            {% if loop.index == 1 %}
            <img src="/assets/icon_stats_home.svg" alt="Home icon">
            {% elif loop.index == 2 %}
            <img src="/assets/icon_stats_5-stars.svg" alt="Five star review icon">
            {% else %}
            <img src="{{ highlights.statsIcon.src | default('/assets/icon_stats_full-kitchen-reno.svg') }}" alt="{{ highlights.statsIcon.alt | default('Kitchen renovation icon') }}">
            {% endif %}
          </div>
          {% for line in card.label %}{{ line }}{% if not loop.last %} <br>{% endif %}{% endfor %}
        </h3>
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if sections["google-review"] %}
    {% set review = sections["google-review"] %}
    <section id="google-review" class="--l-testimonial --bg-2 --narrowSection4">
        <h2 class="--t-small-2a">Google Review</h2>
        <blockquote class="--bg-1">
          <p class="--t-h1">“{{ review.quote }}”</p>
          <footer>
            <cite class="--t-small-2">{{ review.cite }}</cite>
          </footer>
        </blockquote>
    </section>
    {% endif %}

    {% if sections["flood-notice"] %}
    {% set floodNotice = sections["flood-notice"] %}
    <section id="flood-notice" class="--l-floodNotice --bg-1 --narrowSection4">
      <div class="icon" aria-hidden="true">
        <svg viewBox="0 0 48 48" role="img">
          <path d="M24 5.5C18.2 13.4 11.5 21 11.5 29.1A12.5 12.5 0 0 0 24 41.5a12.5 12.5 0 0 0 12.5-12.4C36.5 21 29.8 13.4 24 5.5Z"/>
          <path d="M17 30.5c2.2 0 2.2-1.5 4.5-1.5s2.2 1.5 4.5 1.5 2.2-1.5 4.5-1.5"/>
          <path d="M18.5 35c1.8 0 2-1.1 3.8-1.1s2 1.1 3.8 1.1 2-1.1 3.8-1.1"/>
        </svg>
      </div>
      <div class="content">
        <h2>{{ floodNotice.heading }}</h2>
        <p>{{ floodNotice.text }}</p>
      </div>
    </section>
    {% endif %}

    {% if sections["before-after"] %}
    {% set beforeAfter = sections["before-after"] %}
    <section id="before-after" class="--l-beforeAfter --narrowSection4">
      <h2>{{ beforeAfter.heading }}</h2>
      <p>{{ beforeAfter.text }}</p>
      <div class="container">
        {% for image in beforeAfter.images %}
        <div class="imgWrapper">
          {% if loop.index == 1 %}
          <div class="label before --t-small-2">Before</div><img src="{{ image.src }}" alt="{{ image.alt }}"/></div>
          {% else %}
          <div class="label after --t-small-2">After</div><img src="{{ image.src }}" alt="{{ image.alt }}"/></div>
          {% endif %}
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if sections["kitchen-inquiry"] %}
    {% set inquiry = sections["kitchen-inquiry"] %}
    <section id="kitchen-inquiry" class="--bg-2 --l-1">
      <form action="{{ inquiry.form.action }}" class="--bg-1 form1" name="g-ads-form1" netlify>
        <h2 class="--t-h1">{{ inquiry.form.heading }}</h2>
        <div class="formGroup">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="formGroup">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="formGroup">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <button class="bLink-3" type="submit">{{ inquiry.form.button }}</button>
      </form>
      <div class="imgWrapper"><img src="{{ inquiry.image.src }}" alt="{{ inquiry.image.alt }}"></div>
    </section>
    {% endif %}

    {% if sections["about-verawood"] %}
    {% set about = sections["about-verawood"] %}
    <section id="about-verawood" class="--l-1">
      <div class="spread">
        <h2>{% for line in about.heading %}{{ line }}{% if not loop.last %}<br>{% endif %}{% endfor %}</h2>
        <p>{% for paragraph in about.paragraphs %}{{ paragraph }}{% if not loop.last %}<br><br>{% endif %}{% endfor %}</p>
        <div class="--sprayout-1">
          {% for card in about.cards %}
          <div class="card spread">
            <h3 class="--t-small-3">{{ card.heading }}</h3>
            <p class="--t-p-3">{{ card.text }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
      <div class="imgWrapper"><img src="{{ about.image.src }}" alt="{{ about.image.alt }}"></div>
    </section>
    {% endif %}

    {% if sections["ready-to-start"] %}
    {% set ready = sections["ready-to-start"] %}
    <section id="ready-to-start" class="--invertColor --bg-3 --l-cta2 --narrowSection6">
      <h2>{{ ready.heading }}</h2>
      <p>{{ ready.text }}</p>
      <form action="{{ ready.form.action }}" name="g-ads-form2" netlify>
        <div class="container">
          <div class="formGroup">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="formGroup">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
        </div>
        <div class="formGroup">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <button class="bLink-1" type="submit">{{ ready.form.button }}</button>
      </form>
    </section>
    {% endif %}
  </main>
  {# Footer section of the page #}
  <footer id="root-footer" class="--invertColor --bg-3">
    <div class="container">
      <div class="descriptionContainer">
        <a href="/" class="iconLink"><img src="/assets/logo_small_light.svg" alt="Verawood Construction logo"> </a>
        <p class="--t-p-3">Verawood Construction provides kitchen renovations and home renovation services across Ottawa, Kanata, Nepean, and Orleans. The team is known for professional work, clear communication, and integrity.</p>
      </div>
      <div class="infoContainer">
        <div class="contactContainer">
          <div class="--t-p-2 title">Contact</div>
          <ul>
            <li>
              <a class="--t-p-3" href="mailto:info@verawoodconstruction.com">Info@verawoodconstruction.com</a>
            </li>
            <li>
              <a class="--t-p-3" href="tel:+6138940745">(613) 894 - 0745</a>
            </li>
            <li>
              <address class="--t-p-3">6 Antares Dr Unit 16, Nepean, ON K2E 8A9</address>
            </li>
          </ul>
        </div>
        <div class="navContainer">
          <div class="--t-p-2 title">Navigation</div>
          <nav>
            <ul>
              <li><a class="--t-p-3" href="/">Home</a></li>
              <li><a class="--t-p-3" href="/about">About Us</a></li>
              <li><a class="--t-p-3" href="/testimonials">Testimonials</a></li>
              <li><a class="--t-p-3" href="/gallery">Gallery</a></li>
              <li><a class="--t-p-3" href="/contact">Contact</a></li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
    <div class="footer-band">Copyright 2024
      <a href="https://showtheworld.digital">Show The World</a>. All rights reserved.</div>
  </footer>
  {# JavaScript files can be included here #}
  {% block body_scripts %}{% endblock body_scripts %}
</body>
</html>
